uartile)\n    Q3 = df[col].quantile(0.75)   # 75th percentile (Upper Quartile)\n    IQR = Q3 - Q1                 # Interquartile Range\n    \n    # Define thresholds for 'normal' data range\n    lower_limit = Q1 - 1.5 * IQR\n    upper_limit = Q3 + 1.5 * IQR\n    \n    # 3. TREATMENT (CAPPING): Apply 'Winsorization'\n    # Values outside limits are 'clipped' to the boundaries instead of being deleted\n    df[col] = df[col].clip(lower=lower_limit, upper=upper_limit)\n    \n    # 4. VISUALIZE AFTER: Plot the cleaned distribution in the right column (index 1)\n    # The boxplot should now show no points outside the whiskers\n    sns.boxplot(x=df[col], ax=axes[i, 1]).set_title(f'Capped Distribution: {col}')\n\n# Optimize layout to prevent overlapping titles/labels and display result\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T18:49:06.547469Z","iopub.execute_input":"2026-04-02T18:49:06.547766Z","iopub.status.idle":"2026-04-02T18:49:08.661948Z","shell.execute_reply.started":"2026-04-02T18:49:06.547738Z","shell.execute_reply":"2026-04-02T18:49:08.660553Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x1500 with 6 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":13},{"cell_type":"code","source":"# Identify data types\ndf.dtypes # The datatypes of each column","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T18:49:08.662960Z","iopub.execute_input":"2026-04-02T18:49:08.663218Z","iopub.status.idle":"2026-04-02T18:49:08.669326Z","shell.execute_reply.started":"2026-04-02T18:49:08.663188Z","shell.execute_reply":"2026-04-02T18:49:08.668336Z"}},"outputs":[{"execution_count":14,"output_type":"execute_result","data":{"text/plain":"Job_Title           object\nExperience_Years     int64\nEducation_Level     object\nSkills_Count         int64\nIndustry            object\nCompany_Size        object\nLocation            object\nRemote_Work         object\nCert